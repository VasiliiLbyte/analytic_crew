# DADATA_API_KEY=your_dadata_key
# APIFNS_API_KEY=your_apifns_key
# NEWSAPI_KEY=your_newsapi_key
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# (остальные добавим позже)

